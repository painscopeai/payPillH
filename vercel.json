{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/apps/web",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
