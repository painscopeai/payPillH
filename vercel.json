{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "apps/api/**"
    },
    "api/health/patient-dashboard-metrics.mjs": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "apps/api/**"
    }
  },
  "rewrites": [
    { "source": "/api/((?!health/patient-dashboard-metrics(?:/|$)).*)", "destination": "/api" },
    { "source": "/api", "destination": "/api" },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/index.html",
      "has": [{ "type": "header", "key": "accept", "value": ".*text/html.*" }]
    }
  ]
}
