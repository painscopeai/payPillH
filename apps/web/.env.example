# Local-only: strip from production. Prefer `npm run dev:mocks` instead of committing true.
# VITE_DEV_MOCKS=true

# Supabase (browser; anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional override for API base (production default is /api)
# VITE_API_BASE_URL=/api

# Supabase Auth URL Configuration → Redirect URLs (add each deployment origin):
#   https://YOUR_DOMAIN/auth/reset-password
#   http://localhost:5173/auth/reset-password
#
# Dashboard → Authentication → Email: fix reset template HTML and use OTP/recovery placeholders
# (e.g. {{ .Token }}) when sending a verification code to the user's inbox.
