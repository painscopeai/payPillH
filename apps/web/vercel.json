{
  "version": 2,
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "../api/**"
    },
    "api/health/patient-dashboard-metrics.mjs": {
      "memory": 1024,
      "maxDuration": 60,
      "includeFiles": "../api/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/health/patient-dashboard-metrics",
      "destination": "/api/health/patient-dashboard-metrics"
    },
    {
      "source": "/api/health/patient-dashboard-metrics/",
      "destination": "/api/health/patient-dashboard-metrics"
    },
    { "source": "/api/(?!health/patient-dashboard-metrics(?:/|$))(.*)", "destination": "/api" },
    { "source": "/api", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
