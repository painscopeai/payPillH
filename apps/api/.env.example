PORT=3001
# Local dev: copy to `.env` in repo root or apps/api. On Vercel, use Project Settings → Environment Variables only (`VERCEL=1` is set automatically — `.env` files are not loaded).

# Optional. On Vercel, defaults to https://$VERCEL_URL if unset (see apps/api/src/app.js).
# CORS_ORIGIN=https://your-app.vercel.app

# Supabase (required for JWT auth middleware and server-side data)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Required on Vercel for admin dashboards/lists — bypasses RLS so counts include all patients (Dashboard → Settings → API → service_role secret).
SUPABASE_SERVICE_ROLE_KEY=
# Optional but strongly recommended on Vercel: Dashboard → Settings → API → JWT Secret.
# Verifies access tokens locally (no getUser() round-trip), avoiding 60s serverless timeouts.
SUPABASE_JWT_SECRET=

GEMINI_API_KEY=

# Resend (transactional email — server only)
RESEND_API_KEY=
RESEND_FROM=
