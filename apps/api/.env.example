PORT=3001
# Optional. On Vercel, defaults to https://$VERCEL_URL if unset (see apps/api/src/app.js).
# Comma-separated list allowed for multiple domains.
# CORS_ORIGIN=https://your-app.vercel.app
# Set via `npm run dev:mocks` or to true here — stubs PocketBase in Express routes.
DEV_MOCKS=
GEMINI_API_KEY=
# When DEV_MOCKS is not set, real PocketBase (e.g. Hostinger) needs:
# WEBSITE_DOMAIN=...
# PB_SUPERUSER_EMAIL=...
# PB_SUPERUSER_PASSWORD=...
